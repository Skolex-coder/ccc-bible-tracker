/* =========================================================
   STATE
   ========================================================= */
let readChapters={};
let currentWeek=1;
let darkMode=false;

/* =========================================================
   INIT
   ========================================================= */
function init(){
  loadFromLocalStorage();
  populateWeekSelector();
  updateWeek();
  renderBooks();
  updateOverallProgress();
}

function loadFromLocalStorage(){
  const saved=localStorage.getItem('cccBibleProgress');
  if(saved) readChapters=JSON.parse(saved);
  const savedWeek=localStorage.getItem('cccCurrentWeek');
  if(savedWeek) currentWeek=parseInt(savedWeek);
  const savedDark=localStorage.getItem('cccDarkMode');
  if(savedDark==='true'){
    darkMode=true;
    document.documentElement.setAttribute('data-theme','dark');
    document.getElementById('darkModeBtn').textContent='☀️';
  }
}

function saveToLocalStorage(){
  localStorage.setItem('cccBibleProgress',JSON.stringify(readChapters));
  localStorage.setItem('cccCurrentWeek',currentWeek.toString());
}

/* =========================================================
   DARK MODE
   ========================================================= */
function toggleDarkMode(){
  darkMode=!darkMode;
  if(darkMode){
    document.documentElement.setAttribute('data-theme','dark');
    document.getElementById('darkModeBtn').textContent='☀️';
  }else{
    document.documentElement.removeAttribute('data-theme');
    document.getElementById('darkModeBtn').textContent='🌙';
  }
  localStorage.setItem('cccDarkMode',darkMode.toString());
}

/* =========================================================
   WEEK SELECTOR
   ========================================================= */
function populateWeekSelector(){
  const select=document.getElementById('weekSelect');
  select.innerHTML='';
  for(let i=1;i<=65;i++){
    const w=cccPlan[i];
    const option=document.createElement('option');
    option.value=i;
    option.textContent=w.isSabbath
      ? `Week ${i}: 🌿 ${w.title}`
      : `Week ${i}: ${w.title}`;
    if(i===currentWeek) option.selected=true;
    select.appendChild(option);
  }
}

function updateWeek(){
  const select=document.getElementById('weekSelect');
  currentWeek=parseInt(select.value);
  saveToLocalStorage();
  const w=cccPlan[currentWeek];

  // Phase badge
  renderPhaseBadge(w);

  if(w.isSabbath){
    document.getElementById('memoryCard').style.display='none';
    document.getElementById('bpSection').style.display='none';
    document.getElementById('weekReadingSection').style.display='none';
    document.getElementById('sabbathContent').style.display='block';
    renderSabbathContent(w);
  } else {
    document.getElementById('sabbathContent').style.display='none';
    renderMemoryCard(w);
    renderBPLinks(w);
    renderReadingSection(w);
  }

  loadOBT();
  renderBooks();
}

/* =========================================================
   PHASE BADGE
   ========================================================= */
function renderPhaseBadge(w){
  const badge=document.getElementById('phaseBadge');
  const cls=w.isSabbath?'phase-sabbath':`phase-${w.phase}`;
  badge.innerHTML=`<span class="phase-badge ${cls}">Phase ${w.phase} · ${w.phaseTitle}</span>`;
}

/* =========================================================
   MEMORY VERSE CARD
   ========================================================= */
function renderMemoryCard(w){
  const el=document.getElementById('memoryCard');
  el.style.display='block';
  el.innerHTML=`
    <div class="memory-card" id="memCardInner" onclick="toggleVerseReveal()">
      <div class="memory-card-label">📜 Memory Verse</div>
      <div class="memory-card-ref">${w.memory.ref}</div>
      <div class="memory-card-hint">Tap to reveal verse</div>
      <div class="memory-card-text">${V[w.memory.key]||''}</div>
    </div>`;
}

function toggleVerseReveal(){
  const card=document.getElementById('memCardInner');
  if(card) card.classList.toggle('revealed');
}

/* =========================================================
   BIBLEPROJECT LINKS
   ========================================================= */
function renderBPLinks(w){
  const el=document.getElementById('bpSection');
  if(!w.bp||w.bp.length===0){el.style.display='none';return;}
  el.style.display='block';
  el.innerHTML=`<div class="bp-section"><h3>📺 BibleProject Resources</h3>${
    w.bp.map(b=>`<a class="bp-link" href="${b.u}" target="_blank" rel="noopener">${b.l}</a>`).join('')
  }</div>`;
}

/* =========================================================
   READING LIST
   ========================================================= */
function renderReadingSection(w){
  const el=document.getElementById('weekReadingSection');
  el.style.display='block';

  const allComplete=isWeekComplete(w);
  const btnClass=allComplete?'mark-week-btn done':'mark-week-btn';
  const btnText=allComplete?'✓ Week Complete — Tap to Undo':'Mark This Week Complete';

  el.innerHTML=`
    <div class="week-reading-section">
      <h3>Week ${currentWeek}: ${w.title}</h3>
      <div id="readingList"></div>
      <button class="${btnClass}" id="markWeekBtn" onclick="markWeekAsRead()">${btnText}</button>
    </div>`;

  renderReadingItems(w);
}

function renderReadingItems(w){
  const container=document.getElementById('readingList');
  if(!container) return;
  container.innerHTML='';
  w.readings.forEach((r,idx)=>{
    const done=isReadingComplete(r);
    const label=r.label||autoLabel(r);
    const div=document.createElement('div');
    div.className='reading-item'+(done?' completed':'');
    div.textContent=label;
    div.onclick=()=>toggleReading(r,w);
    container.appendChild(div);
  });
}

function autoLabel(r){
  if(r.ch.length===1) return `${r.book} ${r.ch[0]}`;
  return `${r.book} ${r.ch[0]}–${r.ch[r.ch.length-1]}`;
}

function isReadingComplete(r){
  return r.ch.every(c=>isChapterRead(r.book,c));
}

function isWeekComplete(w){
  return w.readings.every(r=>isReadingComplete(r));
}

function toggleReading(r,w){
  const done=isReadingComplete(r);
  r.ch.forEach(c=>{
    if(!readChapters[r.book]) readChapters[r.book]=[];
    if(!done&&!readChapters[r.book].includes(c)){
      readChapters[r.book].push(c);
    } else if(done){
      readChapters[r.book]=readChapters[r.book].filter(x=>x!==c);
    }
  });
  saveToLocalStorage();
  updateOverallProgress();
  renderReadingItems(w);
  updateMarkWeekButton(w);
  renderBooks();
  const cv=document.getElementById(`chapters-${r.book}`);
  if(cv&&cv.classList.contains('open')) renderChapters(r.book);
}

function updateMarkWeekButton(w){
  const btn=document.getElementById('markWeekBtn');
  if(!btn) return;
  const done=isWeekComplete(w);
  btn.className=done?'mark-week-btn done':'mark-week-btn';
  btn.textContent=done?'✓ Week Complete — Tap to Undo':'Mark This Week Complete';
}

function markWeekAsRead(){
  const w=cccPlan[currentWeek];
  if(w.isSabbath) return;
  const wasComplete=isWeekComplete(w);
  w.readings.forEach(r=>{
    r.ch.forEach(c=>markChapterRead(r.book,c,!wasComplete));
  });
  saveToLocalStorage();
  updateOverallProgress();
  renderReadingItems(w);
  updateMarkWeekButton(w);
  renderBooks();
  if(!wasComplete) launchConfetti();
}

/* =========================================================
   SABBATH CONTENT
   ========================================================= */
function renderSabbathContent(w){
  const el=document.getElementById('sabbathContent');
  const jubilee=w.isJubilee;
  let html=`
    <div class="sabbath-header${jubilee?' jubilee':''}">
      <h2>${jubilee?'🎉 Sabbath & Jubilee!':'🌿 Sabbath Week'}</h2>
      <p>${jubilee
        ?'A double rest — the halfway Jubilee! Catch up on any readings, celebrate how far you\'ve come, and press on.'
        :'A week to rest, catch up on any missed readings, review what God has been teaching you, and breathe.'
      }</p>
    </div>`;

  // Catch-up: unread from block
  html+=renderCatchupHTML(w.block);

  // Block memory verse cards
  html+=renderBlockMemoryHTML(w.block);

  // Block OBT recap
  html+=renderBlockOBTHTML(w.block);

  el.innerHTML=html;

  // Attach toggle listeners for block memory cards
  el.querySelectorAll('.block-memory-card').forEach(card=>{
    card.addEventListener('click',()=>card.classList.toggle('revealed'));
  });
}

function renderCatchupHTML(block){
  let anyUnread=false;
  let html='<div class="catchup-section"><h3>📋 Catch-up — Unread from This Block</h3>';

  block.forEach(wkNum=>{
    const w=cccPlan[wkNum];
    const unread=[];
    w.readings.forEach(r=>{
      r.ch.forEach(c=>{
        if(!isChapterRead(r.book,c)){
          unread.push({book:r.book,ch:c});
          anyUnread=true;
        }
      });
    });

    if(unread.length>0){
      html+=`<div class="catchup-week-block">`;
      html+=`<div class="catchup-week-title">Week ${wkNum} — ${w.title}</div>`;
      // Group by book
      const byBook={};
      unread.forEach(u=>{
        if(!byBook[u.book]) byBook[u.book]=[];
        byBook[u.book].push(u.ch);
      });
      Object.entries(byBook).forEach(([book,chs])=>{
        chs.sort((a,b)=>a-b);
        html+=`<span class="catchup-item">${book} ${chs.join(', ')}</span>`;
      });
      html+=`</div>`;
    } else {
      html+=`<div class="catchup-week-block">`;
      html+=`<div class="catchup-week-title">Week ${wkNum} — ${w.title}</div>`;
      html+=`<span class="catchup-complete">✓ Complete</span>`;
      html+=`</div>`;
    }
  });

  if(!anyUnread){
    html=`<div class="catchup-section"><h3>📋 Catch-up</h3><div class="catchup-all-done">🎉 You're all caught up — nothing to catch up on!</div>`;
  }

  html+='</div>';
  return html;
}

function renderBlockMemoryHTML(block){
  let html=`<div class="block-memory-section"><h3>📜 Memory Verses from This Block</h3><div class="block-memory-grid">`;
  block.forEach(wkNum=>{
    const w=cccPlan[wkNum];
    const text=V[w.memory.key]||'';
    html+=`
      <div class="block-memory-card">
        <div class="block-memory-card-week">Week ${wkNum}</div>
        <div class="block-memory-card-title">${w.title}</div>
        <div class="block-memory-card-ref">${w.memory.ref}</div>
        <div class="block-memory-card-text">${text}</div>
      </div>`;
  });
  html+='</div></div>';
  return html;
}

function renderBlockOBTHTML(block){
  let html=`<div class="block-obt-section"><h3>✏️ Your Reflections from This Block</h3>`;
  block.forEach(wkNum=>{
    const w=cccPlan[wkNum];
    const saved=localStorage.getItem(`cccOBT_${wkNum}`)||'';
    html+=`<div class="block-obt-entry">
      <div class="block-obt-week">Week ${wkNum} — ${w.title}</div>
      ${saved
        ?`<div class="block-obt-text">"${saved}"</div>`
        :`<div class="block-obt-empty">Nothing recorded for this week.</div>`
      }
    </div>`;
  });
  html+='</div>';
  return html;
}

/* =========================================================
   OBT (ONE BIG THING)
   ========================================================= */
function loadOBT(){
  const textarea=document.getElementById('obtTextarea');
  const saved=localStorage.getItem(`cccOBT_${currentWeek}`)||'';
  textarea.value=saved;
  updateOBTNote(saved);

  textarea.oninput=function(){
    localStorage.setItem(`cccOBT_${currentWeek}`,this.value);
    updateOBTNote(this.value);
  };
}

function updateOBTNote(val){
  const note=document.getElementById('obtSavedNote');
  note.textContent=val?'Saved ✓':'';
}

/* =========================================================
   OVERALL PROGRESS
   ========================================================= */
function updateOverallProgress(){
  const total=Object.values(bibleData).reduce((a,b)=>a+b,0);
  const read=Object.values(readChapters).reduce((s,a)=>s+a.length,0);
  const pct=(read/total*100).toFixed(1);
  document.getElementById('overallPercent').textContent=`${pct}%`;
  document.getElementById('overallProgressBar').style.width=`${pct}%`;
  document.getElementById('chaptersRead').textContent=read;
  const done=Object.keys(bibleData).filter(b=>{
    const p=getBookProgress(b);
    return p.read===p.total&&p.total>0;
  }).length;
  document.getElementById('booksCompleted').textContent=done;
}

/* =========================================================
   CHAPTER / BOOK TRACKING
   ========================================================= */
function isChapterRead(book,ch){
  return readChapters[book]&&readChapters[book].includes(ch);
}

function isChapterInCurrentWeek(book,ch){
  const w=cccPlan[currentWeek];
  if(w.isSabbath) return false;
  return w.readings.some(r=>r.book===book&&r.ch.includes(ch));
}

function markChapterRead(book,ch,isRead){
  if(!readChapters[book]) readChapters[book]=[];
  if(isRead&&!readChapters[book].includes(ch)){
    readChapters[book].push(ch);
  } else if(!isRead){
    readChapters[book]=readChapters[book].filter(x=>x!==ch);
  }
}

function getBookProgress(book){
  const total=bibleData[book];
  const read=readChapters[book]?readChapters[book].length:0;
  return{read,total,percent:read/total*100};
}

function renderBooks(){
  const container=document.getElementById('booksContainer');
  container.innerHTML='';
  Object.keys(bibleData).forEach(book=>{
    const p=getBookProgress(book);
    const div=document.createElement('div');
    div.className='book-item';
    div.innerHTML=`
      <div class="book-header" onclick="toggleBook('${book}')">
        <span style="font-weight:600">${book}</span>
        <span>${p.read}/${p.total}</span>
      </div>
      <div class="book-progress-bar">
        <div class="book-progress-fill" style="width:${p.percent}%"></div>
      </div>
      <div class="chapters-view" id="chapters-${book}">
        <div class="chapters-grid" id="grid-${book}"></div>
      </div>`;
    container.appendChild(div);
  });
}

function updateBookProgress(book){
  const p=getBookProgress(book);
  const header=document.querySelector(`#booksContainer .book-item .book-header`);
  // Re-render just this book's header if needed — simpler to just update DOM directly
  const bookItems=document.querySelectorAll('.book-item');
  bookItems.forEach(item=>{
    const nameEl=item.querySelector('.book-header span');
    if(nameEl&&nameEl.textContent===book){
      const countEl=item.querySelectorAll('.book-header span')[1];
      if(countEl) countEl.textContent=`${p.read}/${p.total}`;
      const fill=item.querySelector('.book-progress-fill');
      if(fill) fill.style.width=`${p.percent}%`;
    }
  });
}

function toggleBook(book){
  const view=document.getElementById(`chapters-${book}`);
  if(!view) return;
  if(view.classList.contains('open')){
    view.classList.remove('open');
  } else {
    view.classList.add('open');
    renderChapters(book);
  }
}

function renderChapters(book){
  const grid=document.getElementById(`grid-${book}`);
  if(!grid) return;
  grid.innerHTML='';
  for(let i=1;i<=bibleData[book];i++){
    const box=document.createElement('div');
    box.className='chapter-box';
    box.textContent=i;
    if(isChapterRead(book,i)) box.classList.add('read');
    if(isChapterInCurrentWeek(book,i)){
      box.classList.add('current-week');
    } else {
      box.classList.add('not-current-week');
    }
    box.onclick=()=>{
      const was=isChapterRead(book,i);
      markChapterRead(book,i,!was);
      saveToLocalStorage();
      updateOverallProgress();
      box.classList.toggle('read',!was);
      updateBookProgress(book);
      const w=cccPlan[currentWeek];
      if(!w.isSabbath) updateMarkWeekButton(w);
    };
    grid.appendChild(box);
  }
}

/* =========================================================
   CONFETTI
   ========================================================= */
function launchConfetti(){
  const colours=['#667eea','#764ba2','#f59e0b','#10b981','#ef4444','#3b82f6','#fbbf24','#a78bfa'];
  const container=document.getElementById('confettiContainer');
  container.innerHTML='';
  for(let i=0;i<70;i++){
    const p=document.createElement('div');
    p.className='confetti-piece';
    const size=Math.random()*10+5;
    p.style.cssText=`
      left:${Math.random()*100}%;
      width:${size}px;
      height:${size}px;
      background:${colours[Math.floor(Math.random()*colours.length)]};
      animation-delay:${Math.random()*0.6}s;
      animation-duration:${Math.random()*1.5+2}s;
      border-radius:${Math.random()>0.5?'50%':'2px'};
    `;
    container.appendChild(p);
  }
  setTimeout(()=>container.innerHTML='',3500);
}

/* =========================================================
   TOAST
   ========================================================= */
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

/* =========================================================
   SAVE / IMPORT PROGRESS
   ========================================================= */
function getAllNotes(){
  const notes={};
  for(let i=1;i<=65;i++){
    const v=localStorage.getItem(`cccOBT_${i}`);
    if(v) notes[i]=v;
  }
  return notes;
}

function saveProgressToFile(){
  const notes=getAllNotes();
  const data={
    version:2,
    appName:"CCC Bible Tracker",
    savedAt:new Date().toISOString(),
    currentWeek,
    darkMode,
    readChapters,
    weekNotes:notes
  };
  const json=JSON.stringify(data,null,2);
  const blob=new Blob([json],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;
  a.download='CCC_Progress.json';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('✅ Progress saved to CCC_Progress.json');
}

function importProgressFromFile(event){
  const file=event.target.files[0];
  if(!file) return;
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const data=JSON.parse(e.target.result);
      if(!data.version||!data.readChapters){
        showToast('❌ Not a valid CCC progress file.');
        return;
      }
      // Restore state
      readChapters=data.readChapters||{};
      currentWeek=data.currentWeek||1;
      darkMode=data.darkMode||false;

      // Restore dark mode
      if(darkMode){
        document.documentElement.setAttribute('data-theme','dark');
        document.getElementById('darkModeBtn').textContent='☀️';
      } else {
        document.documentElement.removeAttribute('data-theme');
        document.getElementById('darkModeBtn').textContent='🌙';
      }
      localStorage.setItem('cccDarkMode',darkMode.toString());

      // Restore notes
      if(data.weekNotes){
        Object.entries(data.weekNotes).forEach(([k,v])=>{
          localStorage.setItem(`cccOBT_${k}`,v);
        });
      }

      saveToLocalStorage();

      // Update UI
      document.getElementById('weekSelect').value=currentWeek;
      updateWeek();
      renderBooks();
      updateOverallProgress();
      showToast('✅ Progress imported successfully!');
    }catch(err){
      showToast('❌ Error reading file. Is it a valid CCC progress file?');
    }
  };
  reader.readAsText(file);
  // Reset input so same file can be re-imported
  event.target.value='';
}

/* =========================================================
   RESET
   ========================================================= */
function resetProgress(){
  if(!confirm('Reset ALL progress, notes, and saved data? This cannot be undone.')) return;
  readChapters={};
  currentWeek=1;
  for(let i=1;i<=65;i++) localStorage.removeItem(`cccOBT_${i}`);
  saveToLocalStorage();
  document.getElementById('weekSelect').value=1;
  updateWeek();
  updateOverallProgress();
  renderBooks();
  showToast('Progress reset.');
}

/* =========================================================
   START
   ========================================================= */
window.onload=init;
