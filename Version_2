<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>CCC Bible Tracker V2</title>
<style>
:root{
  --bg-gradient-1:#667eea;--bg-gradient-2:#764ba2;
  --bg-primary:#f9fafb;--bg-secondary:#fff;--bg-tertiary:#f3f4f6;
  --text-primary:#1f2937;--text-secondary:#6b7280;--text-tertiary:#9ca3af;
  --border-color:#e5e7eb;--accent-color:#2563eb;--accent-hover:#1e40af;
  --shadow:rgba(0,0,0,.1);--shadow-heavy:rgba(0,0,0,.3);
  --phase1:#2563eb;--phase2:#059669;--phase3:#d97706;--phase4:#7c3aed;
  --sabbath-bg:#f0fdf4;--sabbath-border:#bbf7d0;--sabbath-text:#166534;
}
[data-theme=dark]{
  --bg-gradient-1:#1e293b;--bg-gradient-2:#0f172a;
  --bg-primary:#1e293b;--bg-secondary:#334155;--bg-tertiary:#475569;
  --text-primary:#f1f5f9;--text-secondary:#cbd5e1;--text-tertiary:#94a3b8;
  --border-color:#475569;--accent-color:#3b82f6;--accent-hover:#2563eb;
  --shadow:rgba(0,0,0,.3);--shadow-heavy:rgba(0,0,0,.5);
  --sabbath-bg:#14532d;--sabbath-border:#166534;--sabbath-text:#86efac;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:linear-gradient(135deg,var(--bg-gradient-1) 0%,var(--bg-gradient-2) 100%);min-height:100vh;padding:20px;color:var(--text-primary);transition:background .3s}
.container{max-width:800px;margin:0 auto;background:var(--bg-primary);border-radius:20px;box-shadow:0 20px 60px var(--shadow-heavy);overflow:hidden}
.header{background:linear-gradient(135deg,var(--accent-color) 0%,var(--accent-hover) 100%);color:#fff;padding:30px 20px;text-align:center;position:relative}
.header h1{font-size:28px;margin-bottom:6px;font-weight:700}
.header p{opacity:.9;font-size:14px}
.header .subtitle{font-size:12px;opacity:.7;margin-top:4px}
.dark-mode-toggle{position:absolute;top:20px;right:20px;background:rgba(255,255,255,.2);border:none;width:40px;height:40px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;transition:all .3s}
.dark-mode-toggle:hover{background:rgba(255,255,255,.3);transform:scale(1.1)}
.content{padding:20px}

/* Week selector */
.week-selector{background:var(--bg-secondary);border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.week-selector h2{font-size:18px;margin-bottom:12px;color:var(--text-primary)}
select{width:100%;padding:12px;border:2px solid var(--border-color);border-radius:8px;font-size:15px;background:var(--bg-primary);color:var(--text-primary);cursor:pointer}

/* Phase badge */
.phase-badge{display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;letter-spacing:.5px;margin-bottom:14px;color:#fff}
.phase-1{background:var(--phase1)}
.phase-2{background:var(--phase2)}
.phase-3{background:var(--phase3)}
.phase-4{background:var(--phase4)}
.phase-sabbath{background:#6b7280}

/* Memory verse card */
.memory-card{background:linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%);border-radius:12px;padding:18px 20px;margin-bottom:16px;box-shadow:0 4px 12px rgba(245,158,11,.3);color:#78350f;cursor:pointer;transition:transform .2s}
.memory-card:hover{transform:translateY(-2px)}
[data-theme=dark] .memory-card{color:#451a03}
.memory-card-label{font-size:11px;text-transform:uppercase;letter-spacing:1px;opacity:.7;margin-bottom:6px;font-weight:600}
.memory-card-ref{font-size:20px;font-weight:700}
.memory-card-hint{font-size:12px;opacity:.6;margin-top:4px}
.memory-card-text{font-size:15px;font-style:italic;line-height:1.6;margin-top:10px;padding-top:10px;border-top:1px solid rgba(120,53,15,.2);display:none}
.memory-card.revealed .memory-card-text{display:block}
.memory-card.revealed .memory-card-hint{display:none}

/* BibleProject links */
.bp-section{background:var(--bg-secondary);border-radius:12px;padding:16px 20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.bp-section h3{font-size:14px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px}
.bp-link{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border-color);text-decoration:none;color:var(--accent-color);font-size:14px;transition:opacity .2s}
.bp-link:last-child{border-bottom:none;padding-bottom:0}
.bp-link:hover{opacity:.7}
.bp-link::before{content:"▶";font-size:10px;opacity:.6}

/* Week readings */
.week-reading-section{background:#fef3c7;border-left:4px solid #f59e0b;padding:16px;border-radius:8px;margin-bottom:16px}
[data-theme=dark] .week-reading-section{background:#422006}
.week-reading-section h3{font-size:16px;font-weight:600;margin-bottom:12px;color:var(--text-primary)}
.reading-item{background:#fff;padding:10px 14px;border-radius:6px;font-size:14px;margin-bottom:8px;cursor:pointer;transition:all .2s;border:2px solid transparent;color:#1f2937}
.reading-item:hover{transform:translateY(-1px);box-shadow:0 4px 8px var(--shadow)}
[data-theme=dark] .reading-item{background:var(--bg-tertiary);color:var(--text-primary)}
.reading-item.completed{border:2px solid #10b981;background:#d1fae5;color:#065f46}
[data-theme=dark] .reading-item.completed{background:#064e3b;color:#6ee7b7}
.mark-week-btn{background:var(--accent-color);color:#fff;border:none;padding:11px 20px;border-radius:6px;font-weight:600;cursor:pointer;width:100%;margin-top:12px;font-size:15px;transition:background .2s}
.mark-week-btn:hover{background:var(--accent-hover)}
.mark-week-btn.done{background:#10b981}
.mark-week-btn.done:hover{background:#059669}

/* OBT Section */
.obt-section{background:var(--bg-secondary);border-radius:12px;padding:18px 20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.obt-section h3{font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:6px}
.obt-section p{font-size:13px;color:var(--text-secondary);margin-bottom:10px;font-style:italic}
.obt-textarea{width:100%;min-height:90px;padding:10px 12px;border:2px solid var(--border-color);border-radius:8px;font-size:14px;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);resize:vertical;transition:border-color .2s;line-height:1.5}
.obt-textarea:focus{outline:none;border-color:var(--accent-color)}
.obt-saved-note{font-size:11px;color:var(--text-tertiary);margin-top:5px;text-align:right;transition:opacity .3s}

/* Sabbath week */
.sabbath-header{background:var(--sabbath-bg);border:2px solid var(--sabbath-border);border-radius:12px;padding:20px;margin-bottom:16px;text-align:center}
.sabbath-header h2{font-size:22px;color:var(--sabbath-text);margin-bottom:6px}
.sabbath-header p{font-size:14px;color:var(--sabbath-text);opacity:.8;line-height:1.5}
.sabbath-header.jubilee{background:linear-gradient(135deg,#fef3c7,#f0fdf4);border-color:#f59e0b}

/* Catch-up section */
.catchup-section{background:var(--bg-secondary);border-radius:12px;padding:18px 20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.catchup-section h3{font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:14px}
.catchup-week-block{margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--border-color)}
.catchup-week-block:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.catchup-week-title{font-size:13px;font-weight:600;color:var(--text-secondary);margin-bottom:6px}
.catchup-item{display:inline-block;background:var(--bg-tertiary);border:1px solid var(--border-color);border-radius:4px;padding:3px 8px;font-size:12px;margin:2px;color:var(--text-primary)}
.catchup-complete{color:#10b981;font-size:13px;font-weight:600}
.catchup-all-done{text-align:center;padding:20px;color:#10b981;font-size:16px;font-weight:600}

/* Block memory verse cards (Sabbath review) */
.block-memory-section{background:var(--bg-secondary);border-radius:12px;padding:18px 20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.block-memory-section h3{font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:14px}
.block-memory-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media(max-width:500px){.block-memory-grid{grid-template-columns:1fr}}
.block-memory-card{background:linear-gradient(135deg,#fef3c7,#fde68a);border-radius:8px;padding:12px;cursor:pointer;transition:transform .2s;color:#78350f}
[data-theme=dark] .block-memory-card{color:#451a03}
.block-memory-card:hover{transform:translateY(-2px)}
.block-memory-card-week{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;opacity:.6;margin-bottom:3px}
.block-memory-card-ref{font-size:14px;font-weight:700}
.block-memory-card-title{font-size:11px;opacity:.7;margin-bottom:5px}
.block-memory-card-text{font-size:12px;font-style:italic;line-height:1.5;margin-top:6px;padding-top:6px;border-top:1px solid rgba(120,53,15,.2);display:none}
.block-memory-card.revealed .block-memory-card-text{display:block}

/* Block OBT recap */
.block-obt-section{background:var(--bg-secondary);border-radius:12px;padding:18px 20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.block-obt-section h3{font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:14px}
.block-obt-entry{padding:10px 0;border-bottom:1px solid var(--border-color)}
.block-obt-entry:last-child{border-bottom:none}
.block-obt-week{font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:4px}
.block-obt-text{font-size:14px;color:var(--text-primary);font-style:italic;line-height:1.5}
.block-obt-empty{font-size:13px;color:var(--text-tertiary);font-style:italic}

/* Overall progress */
.overall-progress{background:var(--bg-secondary);border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.progress-header{display:flex;justify-content:space-between;margin-bottom:12px;align-items:center}
.progress-title{font-size:16px;font-weight:600;color:var(--text-primary)}
.progress-percent{font-size:22px;font-weight:700;color:var(--accent-color)}
.progress-bar-container{height:28px;background:var(--bg-tertiary);border-radius:14px;overflow:hidden}
.progress-bar{height:100%;background:linear-gradient(90deg,var(--accent-color) 0%,#7c3aed 100%);transition:width .4s ease;border-radius:14px}
.stats{display:flex;justify-content:space-around;margin-top:14px;padding-top:14px;border-top:1px solid var(--border-color)}
.stat-number{font-size:24px;font-weight:700;color:var(--accent-color)}
.stat-label{font-size:12px;color:var(--text-secondary)}

/* Books grid */
.books-container{background:var(--bg-secondary);border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px var(--shadow)}
.book-item{padding:13px 0;border-bottom:1px solid var(--bg-tertiary);cursor:pointer}
.book-item:last-child{border-bottom:none}
.book-header{display:flex;justify-content:space-between;margin-bottom:6px}
.book-progress-bar{height:5px;background:var(--bg-tertiary);border-radius:3px;overflow:hidden}
.book-progress-fill{height:100%;background:linear-gradient(90deg,var(--accent-color) 0%,#7c3aed 100%)}
.chapters-view{display:none;margin-top:10px}
.chapters-view.open{display:block}
.chapters-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(38px,1fr));gap:6px;margin-top:8px}
.chapter-box{aspect-ratio:1;border:2px solid var(--border-color);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;cursor:pointer;background:var(--bg-secondary);transition:all .15s}
.chapter-box:hover{transform:scale(1.1)}
.chapter-box.read{background:linear-gradient(135deg,var(--accent-color) 0%,#7c3aed 100%);color:#fff;border-color:transparent}
.chapter-box.current-week{border-color:#f59e0b;border-width:2px}
.chapter-box.not-current-week{opacity:.35}
.chapter-box.read.not-current-week{opacity:.6}

/* Footer buttons */
.footer-buttons{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px;margin-bottom:4px}
.btn-save{background:#2563eb;color:#fff;border:none;padding:11px 16px;border-radius:8px;font-weight:600;cursor:pointer;font-size:14px;transition:background .2s}
.btn-save:hover{background:#1e40af}
.btn-import{background:#059669;color:#fff;border:none;padding:11px 16px;border-radius:8px;font-weight:600;cursor:pointer;font-size:14px;transition:background .2s}
.btn-import:hover{background:#047857}
.btn-reset{background:#ef4444;color:#fff;border:none;padding:11px 16px;border-radius:8px;font-weight:600;cursor:pointer;font-size:14px;transition:background .2s;grid-column:1/-1}
.btn-reset:hover{background:#dc2626}
.import-file-input{display:none}

/* Toast notification */
.toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(100px);background:#1f2937;color:#fff;padding:12px 24px;border-radius:8px;font-size:14px;font-weight:500;z-index:10000;transition:transform .3s ease;pointer-events:none}
.toast.show{transform:translateX(-50%) translateY(0)}

/* Confetti */
.confetti-container{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;overflow:hidden}
.confetti-piece{position:absolute;top:-12px;border-radius:2px;animation:confettiFall 2.8s ease-in forwards}
@keyframes confettiFall{
  0%{transform:translateY(0) rotate(0deg) scaleX(1);opacity:1}
  50%{opacity:1}
  100%{transform:translateY(105vh) rotate(900deg) scaleX(-1);opacity:0}
}
</style>
</head>
<body>
<div id="confettiContainer" class="confetti-container"></div>
<div id="toast" class="toast"></div>
<div class="container">
  <div class="header">
    <button class="dark-mode-toggle" onclick="toggleDarkMode()" id="darkModeBtn">🌙</button>
    <h1>📖 CCC Bible Tracker</h1>
    <p>Character-Charged Christianity</p>
    <div class="subtitle">4-Phase · 65-Week Plan</div>
  </div>
  <div class="content">

    <!-- Week selector -->
    <div class="week-selector">
      <h2>Current Week</h2>
      <select id="weekSelect" onchange="updateWeek()"></select>
    </div>

    <!-- Phase badge -->
    <div id="phaseBadge" style="margin-bottom:14px"></div>

    <!-- Memory verse (regular weeks) -->
    <div id="memoryCard" style="display:none"></div>

    <!-- BibleProject links (regular weeks) -->
    <div id="bpSection" style="display:none"></div>

    <!-- Reading list (regular weeks) -->
    <div id="weekReadingSection" style="display:none"></div>

    <!-- Sabbath content -->
    <div id="sabbathContent" style="display:none"></div>

    <!-- OBT (all weeks) -->
    <div id="obtSection" class="obt-section">
      <h3>✏️ One Big Thing</h3>
      <p>What was one big thing from your readings this week?</p>
      <textarea id="obtTextarea" class="obt-textarea" placeholder="Your reflection..."></textarea>
      <div id="obtSavedNote" class="obt-saved-note"></div>
    </div>

    <!-- Overall progress -->
    <div class="overall-progress">
      <div class="progress-header">
        <span class="progress-title">Overall Progress</span>
        <span class="progress-percent" id="overallPercent">0%</span>
      </div>
      <div class="progress-bar-container">
        <div class="progress-bar" id="overallProgressBar" style="width:0%"></div>
      </div>
      <div class="stats">
        <div><div class="stat-number" id="chaptersRead">0</div><div class="stat-label">Chapters Read</div></div>
        <div><div class="stat-number" id="booksCompleted">0</div><div class="stat-label">Books Done</div></div>
      </div>
    </div>

    <!-- Books of the Bible -->
    <div class="books-container">
      <h3 style="margin-bottom:14px;font-size:16px">Books of the Bible</h3>
      <div id="booksContainer"></div>
    </div>

    <!-- Footer buttons -->
    <div class="footer-buttons">
      <button class="btn-save" onclick="saveProgressToFile()">💾 Save My Progress</button>
      <button class="btn-import" onclick="document.getElementById('importInput').click()">📂 Import Progress</button>
      <input type="file" id="importInput" class="import-file-input" accept=".json" onchange="importProgressFromFile(event)">
      <button class="btn-reset" onclick="resetProgress()">🗑 Reset All Progress</button>
    </div>

  </div>
</div>

